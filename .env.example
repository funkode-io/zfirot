# Copy this file to `.env` and fill in your token. `.env` is gitignored.
#
# Create a fine-grained GitHub Personal Access Token at
# https://github.com/settings/personal-access-tokens/new with read access to the
# target repository's Issues, Pull requests, and Contents. The app reads this at
# startup to load the board.
GITHUB_TOKEN=

# Optional: background-poll cadence in seconds (default 60, minimum 5). The board
# also has a manual Refresh button and shows a "last updated" timestamp.
# ZFIROT_POLL_SECS=60
